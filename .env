# AWS RDS MySQL Configuration
# Copy this file to .env and update with your actual credentials
# DO NOT commit .env file to git

# AWS RDS MySQL Endpoint
DB_HOST=quickcommerce.crys0s8colmh.ap-southeast-2.rds.amazonaws.com
DB_PORT=3306
DB_NAME=inventory

# Database Credentials
DB_USERNAME=admin
DB_PASSWORD=mySql123

# Meilisearch Configuration (for search-service)
# Docker Compose: http://meilisearch:7700 (both containers in same network)
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=QuickCommerce2024Prod

# Payment failsafe scheduler — aggressive values while sandbox/mock integration is active.
# Flip to 55000 / 60 once real PawaPay webhook delivery is reliable in production.
PAYMENT_FAILSAFE_INTERVAL_MS=3000
PAYMENT_FAILSAFE_CUTOFF_SECONDS=2

